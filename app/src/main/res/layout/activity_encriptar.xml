<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EncriptarActivity">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_encrypt_file" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="ENCRIPTAR MENSAJE"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <EditText
        android:id="@+id/edtMensaje"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:ems="10"
        android:gravity="top"
        android:hint="Mensaje"
        android:inputType="textMultiLine"
        app:layout_constraintStart_toStartOf="@+id/textView"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <EditText
        android:id="@+id/edtDesplazamiento"
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="25dp"
        android:ems="10"
        android:hint="Desplazamiento"
        android:inputType="number"
        app:layout_constraintStart_toStartOf="@id/edtMensaje"
        app:layout_constraintTop_toBottomOf="@id/edtMensaje" />

    <Button
        android:id="@+id/btnEncriptar"
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="28dp"
        android:text="Encriptar"
        app:layout_constraintStart_toStartOf="@id/edtDesplazamiento"
        app:layout_constraintTop_toBottomOf="@id/edtDesplazamiento" />

    <TextView
        android:id="@+id/txtOriginal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:text="Mensaje original:"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@id/btnEncriptar"
        app:layout_constraintTop_toBottomOf="@id/btnEncriptar" />

    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Mensaje encriptado:"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/txtOriginal"
        app:layout_constraintTop_toBottomOf="@id/txtOriginal" />

    <Button
        android:id="@+id/btnRegresar"
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        android:text="Regresar"
        app:layout_constraintStart_toStartOf="@id/txtResultado"
        app:layout_constraintTop_toBottomOf="@id/txtResultado" />

</androidx.constraintlayout.widget.ConstraintLayout>
